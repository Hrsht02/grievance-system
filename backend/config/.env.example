# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Messaging channel (start with Telegram for free MVP demo) ---
TELEGRAM_BOT_TOKEN=
# Later, when WhatsApp Cloud API is approved:
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# --- AI classification (Google Gemini free tier) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Speech-to-text (choose one) ---
# Option A: self-hosted AI4Bharat / Whisper (no key needed, just endpoint)
STT_ENDPOINT_URL=
# Option B: any hosted STT free-tier fallback
STT_API_KEY=

# --- Database (Supabase free tier recommended) ---
DATABASE_URL=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App config ---
APP_BASE_URL=
DEFAULT_ACK_SLA_MINUTES=30
DEFAULT_RESOLUTION_SLA_HOURS=48
CRITICAL_ACK_SLA_MINUTES=15
CRITICAL_RESOLUTION_SLA_HOURS=4

# --- Telegram bot username (for QR deep-link generation) ---
TELEGRAM_BOT_USERNAME=YourBotUsername

# --- JWT secret for officer/admin dashboard auth ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
